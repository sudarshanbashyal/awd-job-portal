generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  APPLICANT
  RECRUITER
}

enum Level {
  ENTRY_LEVEL
  JUNIOR
  MID_LEVEL
  SENIOR
}

enum JobStatus {
  DRAFTED
  OPEN
  CLOSED
}

enum JobType {
  PART_TIME
  FULL_TIME
}

enum JobArrangement {
  ONSITE
  REMOTE
  HYBRID
}

enum JobApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  WITHDRAWN

  ASSESSMENT
  ASSESSMENT_PASSED

  INTERVIEW
  INTERVIEW_PASSED

  OFFERED
  OFFER_ACCEPTED
  OFFER_REJECTED
}

enum ParsedResumeStatus {
  PARSING
  PARSED
  FAILED
}

enum SkillType {
  SOFT_SKILL
  HARD_SKILL
}

enum UploadType {
  RESUME
  PROFILE_PICTURE
}

model User {
  id             String  @id @default(uuid())
  email          String  @unique
  password       String
  role           Role    @default(APPLICANT)
  profilePicture String?
  profileUpdated Boolean @default(false)

  applicant     Applicant?
  recruiter     Recruiter?
  uploadedFiles UploadedFile[]
  resetTokens   ResetTokens[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Applicant {
  id String @id @default(uuid())

  firstName   String
  lastName    String
  profile     String?
  location    String?
  phoneNumber String?
  resumeLink  String?

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  skills                 Skills[]
  professionalExperience ProfessionalExperience[]
  education              Education[]
  jobApplications        JobApplication[]

  skillAssessments SkillAssessment[]
}

model Skills {
  id          String @id @default(uuid())
  skill       String
  skillRating Int?

  applicant   Applicant? @relation(fields: [applicantId], references: [id])
  applicantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfessionalExperience {
  id String @id @default(uuid())

  role        String
  companyName String
  location    String
  startedAt   DateTime
  endedAt     DateTime?
  description String

  applicant   Applicant? @relation(fields: [applicantId], references: [id])
  applicantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id String @id @default(uuid())

  instituteName String
  course        String
  location      String
  description   String?
  startedAt     DateTime
  endedAt       DateTime?

  applicant   Applicant? @relation(fields: [applicantId], references: [id])
  applicantId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Recruiter {
  id String @id @default(uuid())

  firstName      String
  lastName       String
  companyName    String
  companyAddress String

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  jobPostings JobPosting[]
}

model JobPosting {
  id                String         @id @default(uuid())
  title             String
  summary           String
  description       String
  salaryFrom        Int?
  salaryTo          Int?
  level             Level?
  yearsOfExperience Int?
  jobType           JobType        @default(FULL_TIME)
  location          String
  arrangement       JobArrangement @default(ONSITE)

  status JobStatus @default(DRAFTED)

  postedBy    Recruiter @relation(fields: [recruiterId], references: [id])
  recruiterId String

  jobApplications  JobApplication[]
  skillAssessments SkillAssessment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model JobApplication {
  id String @id @default(uuid())

  resumeLink String

  applicant   Applicant? @relation(fields: [applicantId], references: [id])
  applicantId String

  jobPosting JobPosting @relation(fields: [jobId], references: [id])
  jobId      String

  applicationStatus JobApplicationStatus @default(APPLIED)
  parsedResume      ParsedResume?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParsedResume {
  id String @id @default(uuid())

  status            ParsedResumeStatus @default(PARSING)
  yearsOfExperience Float?
  rating            Int?

  application   JobApplication @relation(fields: [applicationId], references: [id])
  applicationId String         @unique

  extractedSkills ExtractedSkills[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExtractedSkills {
  id String @id @default(uuid())

  skill      String
  confidence Int?
  skillType  SkillType?

  parsedResume   ParsedResume @relation(fields: [parsedResumeId], references: [id])
  parsedResumeId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SkillAssessment {
  id String @id @default(uuid())

  status      ParsedResumeStatus @default(PARSING)
  description String
  rating      Int

  applicant   Applicant @relation(fields: [applicantId], references: [id])
  applicantId String

  jobPosting JobPosting @relation(fields: [jobId], references: [id])
  jobId      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UploadedFile {
  id String @id @default(uuid())

  originalName String
  storedName   String
  mimeType     String?
  size         Int?
  uploadType   UploadType

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResetTokens {
  id String @id @default(uuid())

  token       Int
  generatedBy User   @relation(fields: [userId], references: [id])
  userId      String

  createdAt DateTime @default(now())
  expiresAt DateTime
}
